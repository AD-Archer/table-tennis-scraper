# Required for Prisma/Postgres artifact persistence.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=verify-full"

# Frontend-only check for destructive controls.
NEXT_PUBLIC_MASTER_SYNC_PASSWORD="change-me"

# Server-side password required for /console/errors and /api/admin/* routes.
ADMIN_CONSOLE_PASSWORD="change-me-admin"

# Optional server log level for structured logs: debug | info | warn | error
SERVER_LOG_LEVEL="info"

# Optional pretty JSON logs (default: true in dev, false in production)
SERVER_LOG_PRETTY="true"

# Optional downstream sync target.
SPINDEX_API_BASE_URL=""
SPINDEX_API_TOKEN=""

# Optional pipeline toggle.
WTT_PIPELINE_ENABLED="false"
